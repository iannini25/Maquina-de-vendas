# ── Núcleo ────────────────────────────────────────────────────────────────
APP_URL=https://app.SEUDOMINIO.com
LANDING_URL=https://SEUDOMINIO.com
AUTH_SECRET=
APP_ENCRYPTION_KEY=            # 32 bytes base64 — gere com `pnpm gen:keys`

# ── Infra ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vendaflow:vendaflow@localhost:5432/vendaflow
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vendaflow
S3_REGION=us-east-1

# ── IA (defaults; chaves reais entram pelo Setup Gate, por workspace) ─────
AI_MODEL_CHAT=claude-sonnet-4-6
AI_MODEL_CLASSIFIER=claude-haiku-4-5-20251001
AI_MODEL_HEAVY=claude-opus-4-8
EMBEDDINGS_MODEL=voyage-3

# ── Evolution API (instância padrão do compose) ───────────────────────────
EVOLUTION_URL=http://localhost:8080
EVOLUTION_GLOBAL_KEY=

# ── Diversos ──────────────────────────────────────────────────────────────
SEED_DEMO=true
NODE_ENV=development
