{
  "name": "@vendaflow/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "dev": "tsc -b --watch --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx src/seed/index.ts",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@vendaflow/core": "workspace:*",
    "@vendaflow/eslint-config": "workspace:*",
    "prisma": "^6.16.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.30.0"
  }
}
